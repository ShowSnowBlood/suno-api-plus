# ========= Required for music generation =========
# Suno session cookie (optional if you only use Admin multi-account pool)
SUNO_COOKIE=

# Captcha solver: yescaptcha | 2captcha
CAPTCHA_PROVIDER=2captcha
# 2Captcha API key: https://2captcha.com
TWOCAPTCHA_KEY=
# YesCaptcha API key: https://yescaptcha.com
YESCAPTCHA_KEY=
YESCAPTCHA_BASE_URL=https://api.yescaptcha.com
# auto | token | click
CAPTCHA_MODE=auto

# ========= Browser (Playwright) =========
BROWSER=chromium
BROWSER_GHOST_CURSOR=false
BROWSER_LOCALE=en
BROWSER_HEADLESS=true
BROWSER_DISABLE_GPU=true

# ========= Admin panel =========
# Login password for /admin
ADMIN_PASSWORD=change-this-password
# AES key used to encrypt stored account cookies (set a long random string)
ACCOUNT_ENCRYPTION_KEY=change-this-encryption-key
ACCOUNT_DATA_PATH=/app/data/accounts.json
# Billing settings are managed in /admin and saved as billing-settings.json beside ACCOUNT_DATA_PATH.
# Quota refresh interval (seconds)
ACCOUNT_QUOTA_SYNC_INTERVAL_SEC=300

# ========= OpenAI-compatible API auth (optional, also configurable in Admin UI) =========
# When set, /v1/* requires Authorization: Bearer <key>
API_KEY=
# Or alias:
# SUNO_API_KEY=
# Force enable even if empty (not recommended)
# API_KEY_ENABLED=false
