{
  "openapi": "3.0.3",
  "info": {
    "title": "suno-api",
    "description": "",
    "version": "",
    "license": { "name": "gcui-art", "url": "https://github.com/gcui-art/" }
  },
  "tags": [
    { "name": "\u9ed8\u8ba4\u5206\u7ec4" },
    { "name": "billing" },
    { "name": "admin" },
    { "name": "concurrency" }
  ],
  "paths": {
    "/v1/models": {
      "get": {
        "summary": "List available Suno models.",
        "description": "Returns the OpenAI-compatible model catalog. When API key authentication is enabled, send Authorization: Bearer <API_KEY> (or x-api-key). Use the returned public id in generation requests. Actual availability depends on the selected Suno account plan and upstream permissions.",
        "tags": ["\u9ed8\u8ba4\u5206\u7ec4"],
        "responses": {
          "200": {
            "description": "Available models.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/model_list" },
                "example": {
                  "object": "list",
                  "data": [
                    {
                      "id": "suno-music",
                      "object": "model",
                      "created": 0,
                      "owned_by": "suno-api",
                      "capabilities": ["music"],
                      "metadata": {
                        "provider": "suno",
                        "provider_model": "chirp-fenix",
                        "label": "Suno Music (Latest)",
                        "description": "Recommended OpenAI-compatible alias for the latest Suno music model.",
                        "status": "current",
                        "recommended": true,
                        "alias_of": "chirp-fenix"
                      }
                    },
                    {
                      "id": "suno-v5.5",
                      "object": "model",
                      "created": 0,
                      "owned_by": "suno-api",
                      "capabilities": ["music"],
                      "metadata": {
                        "provider": "suno",
                        "provider_model": "chirp-fenix",
                        "label": "Suno V5.5",
                        "description": "Latest Suno model with improved expression and personalization.",
                        "status": "current",
                        "recommended": false,
                        "alias_of": "chirp-fenix"
                      }
                    },
                    {
                      "id": "suno-v5",
                      "object": "model",
                      "created": 0,
                      "owned_by": "suno-api",
                      "capabilities": ["music"],
                      "metadata": {
                        "provider": "suno",
                        "provider_model": "chirp-crow",
                        "label": "Suno V5",
                        "description": "Previous-generation Suno V5 music model.",
                        "status": "stable",
                        "recommended": false,
                        "alias_of": "chirp-crow"
                      }
                    },
                    {
                      "id": "suno-v4.5+",
                      "object": "model",
                      "created": 0,
                      "owned_by": "suno-api",
                      "capabilities": ["music"],
                      "metadata": {
                        "provider": "suno",
                        "provider_model": "chirp-bluejay",
                        "label": "Suno V4.5+",
                        "description": "Enhanced V4.5 generation model.",
                        "status": "stable",
                        "recommended": false,
                        "alias_of": "chirp-bluejay"
                      }
                    },
                    {
                      "id": "suno-v4.5",
                      "object": "model",
                      "created": 0,
                      "owned_by": "suno-api",
                      "capabilities": ["music"],
                      "metadata": {
                        "provider": "suno",
                        "provider_model": "chirp-auk",
                        "label": "Suno V4.5",
                        "description": "Stable V4.5 generation model.",
                        "status": "stable",
                        "recommended": false,
                        "alias_of": "chirp-auk"
                      }
                    },
                    {
                      "id": "suno-v4",
                      "object": "model",
                      "created": 0,
                      "owned_by": "suno-api",
                      "capabilities": ["music"],
                      "metadata": {
                        "provider": "suno",
                        "provider_model": "chirp-v4",
                        "label": "Suno V4",
                        "description": "Legacy V4 generation model.",
                        "status": "legacy",
                        "recommended": false,
                        "alias_of": "chirp-v4"
                      }
                    },
                    {
                      "id": "suno-v3.5",
                      "object": "model",
                      "created": 0,
                      "owned_by": "suno-api",
                      "capabilities": ["music"],
                      "metadata": {
                        "provider": "suno",
                        "provider_model": "chirp-v3-5",
                        "label": "Suno V3.5",
                        "description": "Legacy V3.5 generation model.",
                        "status": "legacy",
                        "recommended": false,
                        "alias_of": "chirp-v3-5"
                      }
                    },
                    {
                      "id": "suno-v3",
                      "object": "model",
                      "created": 0,
                      "owned_by": "suno-api",
                      "capabilities": ["music"],
                      "metadata": {
                        "provider": "suno",
                        "provider_model": "chirp-v3-0",
                        "label": "Suno V3",
                        "description": "Legacy V3 generation model.",
                        "status": "legacy",
                        "recommended": false,
                        "alias_of": "chirp-v3-0"
