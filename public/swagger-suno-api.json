        }
      }
    },
    "/v1/billing": {
      "get": {
        "summary": "Get active credit and multiplier billing settings.",
        "description": "Returns persisted settings and calculated costs. API key authentication is required when enabled for /v1/*. Defaults: CNY 120 / 2500 credits, 10 credits and 2 songs per request, multiplier 1, and CNY 1 per USD balance unit. Results: CNY 0.048 per credit, CNY 0.48 per request, and CNY 0.24 per song.",
        "tags": ["billing"],
        "security": [{ "BearerAuth": [] }, { "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Active billing settings and calculated summary.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/billing_public_response" } } }
          },
          "401": { "description": "API key required or invalid." },
          "500": { "description": "Billing settings could not be loaded." }
        }
      }
    },
    "/v1/sub2api/billing": {
      "get": {
        "summary": "Declare the upstream rate multiplier to Sub2API.",
        "description": "Sub2API compatibility probe. It exposes the active rateMultiplier using the schema required by Sub2API. This declaration does not change the per-request generation charge.",
        "tags": ["billing"],
        "security": [{ "BearerAuth": [] }, { "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Current upstream multiplier declaration.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/sub2api_key_billing" } } }
          },
          "401": { "description": "API key required or invalid." },
          "500": { "description": "Billing multiplier could not be loaded." }
        }
      }
    },
    "/api/admin/billing": {
      "get": {
        "summary": "Get billing settings for the admin panel.",
        "description": "Requires a valid suno_admin_session cookie created by the admin login flow.",
        "tags": ["admin", "billing"],
        "security": [{ "AdminSession": [] }],
        "responses": {
          "200": {
            "description": "Active billing settings and calculated summary.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/billing_snapshot" } } }
          },
          "401": { "description": "Admin authentication required." },
          "500": { "description": "Billing settings could not be loaded." }
        }
      },
      "put": {
        "summary": "Update billing settings.",
        "description": "Persists positive numeric settings to billing-settings.json beside ACCOUNT_DATA_PATH and applies them immediately without a restart. Requires a valid suno_admin_session cookie.",
        "tags": ["admin", "billing"],
        "security": [{ "AdminSession": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/billing_settings_update" },
              "example": { "purchaseCostCny": 120, "purchasedCredits": 2500, "creditsPerGeneration": 10, "outputsPerGeneration": 2, "rateMultiplier": 1, "cnyPerUsd": 1 }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Billing settings saved and applied.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/billing_admin_save_response" } } }
          },
          "400": { "description": "A supplied setting is not a positive finite number." },
          "401": { "description": "Admin authentication required." },
          "500": { "description": "Billing settings could not be saved." }
        }
      }
    },
    "/api/admin/concurrency": {
      "get": {
        "summary": "Get global generation concurrency settings and live capacity.",
        "description": "Requires a valid suno_admin_session cookie. The default global limit is 4 concurrent generation requests.",
        "tags": ["admin", "concurrency"],
        "security": [{ "AdminSession": [] }],
        "responses": {
          "200": {
            "description": "Current settings, active request count, and available slots.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/concurrency_snapshot" } } }
          },
          "401": { "description": "Admin authentication required." },
          "500": { "description": "Concurrency settings could not be loaded." }
        }
      },
      "put": {
        "summary": "Update the global generation concurrency limit.",
        "description": "Accepts maxConcurrentRequests from 1 to 100 and applies the new limit immediately. Requires a valid suno_admin_session cookie.",
        "tags": ["admin", "concurrency"],
        "security": [{ "AdminSession": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/concurrency_settings_update" } } }
        },
        "responses": {
          "200": {
            "description": "Concurrency setting saved and applied.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/concurrency_save_response" } } }
          },
          "400": { "description": "maxConcurrentRequests is not an integer from 1 to 100." },
          "401": { "description": "Admin authentication required." },
          "500": { "description": "Concurrency settings could not be saved." }
        }
      }
    },
    "/v1/chat/completions": {
      "post": {
        "summary": "Generate music using the OpenAI Chat Completions format.",
        "tags": ["\u9ed8\u8ba4\u5206\u7ec4", "concurrency"],
        "security": [{ "BearerAuth": [] }, { "ApiKeyAuth": [] }],
        "responses": {
          "200": { "description": "Generation completed." },
          "401": { "description": "API key required or invalid." },
          "429": { "$ref": "#/components/responses/ConcurrencyLimitExceeded" }
        }
      }
    },
    "/v1/responses": {
      "post": {
        "summary": "Generate music using the OpenAI Responses format.",
        "tags": ["\u9ed8\u8ba4\u5206\u7ec4", "concurrency"],
        "security": [{ "BearerAuth": [] }, { "ApiKeyAuth": [] }],
        "responses": {
          "200": { "description": "Generation completed." },
          "401": { "description": "API key required or invalid." },
          "429": { "$ref": "#/components/responses/ConcurrencyLimitExceeded" }
        }
      }
    },
    "/api/admin/generate": {
      "post": {
        "summary": "Submit a generation request from the admin panel.",
        "tags": ["admin", "concurrency"],
        "security": [{ "AdminSession": [] }],
        "responses": {
          "200": { "description": "Generation submitted." },
          "401": { "description": "Admin authentication required." },
          "429": { "$ref": "#/components/responses/ConcurrencyLimitExceeded" }
        }
      }
    },
    "/api/extend_audio": {
      "post": {
        "summary": "Extend an existing audio clip.",
        "tags": ["\u9ed8\u8ba4\u5206\u7ec4", "concurrency"],
        "responses": {
          "200": { "description": "Extension submitted or completed." },
          "429": { "$ref": "#/components/responses/ConcurrencyLimitExceeded" }
        }
      }
    },
    "/api/generate_stems": {
      "post": {
        "summary": "Generate stem tracks.",
        "tags": ["\u9ed8\u8ba4\u5206\u7ec4", "concurrency"],
        "responses": {
          "200": { "description": "Stem generation submitted." },
          "429": { "$ref": "#/components/responses/ConcurrencyLimitExceeded" }
        }
      }
    },
    "/api/generate_lyrics": {
      "post": {
        "summary": "Generate lyrics from a prompt.",
        "tags": ["\u9ed8\u8ba4\u5206\u7ec4", "concurrency"],
        "responses": {
          "200": { "description": "Lyrics generated." },
          "429": { "$ref": "#/components/responses/ConcurrencyLimitExceeded" }
        }
      }
    },
    "/api/concat": {
      "post": {
        "summary": "Generate a complete song from extensions.",
        "tags": ["\u9ed8\u8ba4\u5206\u7ec4", "concurrency"],
        "responses": {
          "200": { "description": "Concatenation submitted." },
          "429": { "$ref": "#/components/responses/ConcurrencyLimitExceeded" }
        }
      }
    },
    "/api/custom_generate": {
      "post": {
        "summary": "Generate Audio - Custom Mode",
        "description": "The custom mode enables users to provide additional details about the music, such as music genre, lyrics, and more.2 audio files will be generated for each request, consuming a total of 10 credits.wait_audio can be set to API mode:\u2022 By default, it is set to false, which indicates the background mode. It will only return audio task information, and you will need to call the get API to retrieve detailed audio information.\u2022 If set to true, it simulates synchronous mode. The API will wait for a maximum of 100s until the audio is generated, and will directly return the audio link and other information. Recommend using in GPTs and other agents.",
        "tags": ["\u9ed8\u8ba4\u5206\u7ec4"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["prompt", "tags", "title"],
                "properties": {
                  "prompt": {
                    "type": "string",
                    "description": "Detailed prompt, including information such as music lyrics.",
                    "example": "[Verse 1]\nCruel flames of war engulf this land\nBattlefields filled with death and dread\nInnocent souls in darkness, they rest\nMy heart trembles in this silent test\n\n[Verse 2]\nPeople weep for loved ones lost\nBattered bodies bear the cost\nSeeking peace and hope once known\nOur grief transforms to hearts of stone\n\n[Chorus]\nSilent battlegrounds, no birds' song\nShadows of war, where we don't belong\nMay flowers of peace bloom in this place\nLet's guard this precious dream with grace\n\n[Bridge]\nThrough the ashes, we will rise\nHand in hand, towards peaceful skies\nNo more sorrow, no more pain\nTogether, we'll break these chains\n\n[Chorus]\nSilent battlegrounds, no birds' song\nShadows of war, where we don't belong\nMay flowers of peace bloom in this place\nLet's guard this precious dream with grace\n\n[Outro]\nIn unity, our strength will grow\nA brighter future, we'll soon know\nFrom the ruins, hope will spring\nA new dawn, we'll together bring"
                  },
                  "tags": {
                    "type": "string",
                    "description": "Music genre",
                    "example": "pop metal male melancholic"
                  },
                  "title": {
                    "type": "string",
                    "description": "Music title",
                    "example": "Silent Battlefield"
                  },
                  "make_instrumental": {
                    "type": "boolean",
                    "description": "Whether to generate instrumental music",
                    "example": "false"
                  },
                  "model": {
                    "type": "string",
                    "description": "Public Suno model ID. Defaults to suno-music (currently Suno V5.5 / chirp-fenix). Raw chirp-* identifiers remain pass-through compatible. Availability depends on the account plan and upstream permissions.",
                    "default": "suno-music",
                    "example": "suno-music"
                  },
                  "wait_audio": {
                    "type": "boolean",
                    "description": "Whether to wait for music generation, default is false, directly return audio task information; set to true, will wait for up to 100s until the audio is generated.",
                    "example": "false"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "\u6210\u529f",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["0", "1"],
                    "properties": [
                      { "$ref": "#/components/schemas/audio info" },
                      { "$ref": "#/components/schemas/audio info" }
                    ]
                  }
                }
              }
            }
          },
          "429": { "$ref": "#/components/responses/ConcurrencyLimitExceeded" }
        }
      }
    },
    "/api/generate": {
      "post": {
        "summary": "Generate audio based on Prompt.",
        "description": "It will automatically fill in the lyrics.2 audio files will be generated for each request, consuming a total of 10 credits.wait_audio can be set to API mode:\u2022 By default, it is set to false, which indicates the background mode. It will only return audio task information, and you will need to call the get API to retrieve detailed audio information.\u2022 If set to true, it simulates synchronous mode. The API will wait for a maximum of 100s until the audio is generated, and will directly return the audio link and other information. Recommend using in GPTs and other agents.",
        "tags": ["\u9ed8\u8ba4\u5206\u7ec4"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["prompt", "make_instrumental", "wait_audio"],
                "properties": {
                  "prompt": {
                    "type": "string",
                    "description": "Prompt",
                    "example": "A popular heavy metal song about war, sung by a deep-voiced male singer, slowly and melodiously. The lyrics depict the sorrow of people after the war."
                  },
                  "make_instrumental": {
                    "type": "boolean",
                    "description": "Whether to generate instrumental music",
                    "example": "false"
                  },
                  "model": {
                    "type": "string",
                    "description": "Public Suno model ID. Defaults to suno-music (currently Suno V5.5 / chirp-fenix). Raw chirp-* identifiers remain pass-through compatible. Availability depends on the account plan and upstream permissions.",
                    "default": "suno-music",
                    "example": "suno-music"
                  },
                  "wait_audio": {
                    "type": "boolean",
                    "description": "Whether to wait for music generation, default is false, directly return audio task information; set to true, will wait for up to 100s until the audio is generated.",
                    "example": "false"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "\u6210\u529f",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["0", "1"],
                    "properties": [
                      { "$ref": "#/components/schemas/audio info" },
                      { "$ref": "#/components/schemas/audio info" }
                    ]
                  }
                }
              }
            }
          },
          "429": { "$ref": "#/components/responses/ConcurrencyLimitExceeded" }
        }
      }
    },
    "/api/get": {
      "get": {
        "summary": "Get audio information",
        "description": "",
        "tags": ["\u9ed8\u8ba4\u5206\u7ec4"],
        "parameters": [
          {
            "in": "query",
            "name": "ids",
            "description": "Audio IDs, separated by commas.",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "\u6210\u529f" } }
      }
    },
    "/api/get_limit": {
      "get": {
        "summary": "Get quota information.",
        "description": "",
        "tags": ["\u9ed8\u8ba4\u5206\u7ec4"],
        "responses": {
          "200": {
            "description": "\u6210\u529f",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "credits_left",
                    "period",
                    "monthly_limit",
                    "monthly_usage"
                  ],
                  "properties": {
                    "credits_left": {
                      "type": "number",
                      "description": "Remaining credits,Each generated audio consumes 5 credits."
                    },
                    "period": { "type": "string", "description": "Period" },
                    "monthly_limit": {
                      "type": "number",
                      "description": "Monthly limit"
                    },
                    "monthly_usage": {
                      "type": "number",
                      "description": "Monthly usage"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "audio info": {
        "type": "object",
        "required": [
          "id",
          "title",
          "image_url",
          "lyric",
          "audio_url",
          "video_url",
          "created_at",
          "model_name",
          "status",
          "gpt_description_prompt",
          "prompt",
          "type",
          "tags"
        ],
        "properties": {
          "id": { "type": "string", "description": "audio id" },
          "title": { "type": "string", "description": "music title" },
          "image_url": { "type": "string", "description": "music cover image" },
          "lyric": { "type": "string", "description": "music lyric" },
          "audio_url": {
            "type": "string",
            "description": "music download url"
          },
          "video_url": {
            "type": "string",
            "description": "Music video download link, can be used to share"
          },
          "created_at": { "type": "string", "description": "Create time" },
          "model_name": {
            "type": "string",
            "description": "Raw Suno provider model identifier used by the generated audio, for example chirp-fenix."
          },
          "status": {
            "type": "string",
            "description": "The generated states include submitted, queue, streaming, complete."
          },
          "gpt_description_prompt": {
            "type": "string",
            "description": "Simple mode on user input prompt, Suno will generate formal prompts, lyrics, etc."
          },
          "prompt": {
            "type": "string",
            "description": "The final prompt for executing the generation task, customized by the user in custom mode, automatically generated by Suno in simple mode."
          },
          "type": { "type": "string", "description": "Type" },
          "tags": {
            "type": "string",
            "description": "Music genre. User-provided in custom mode, automatically generated by Suno in simple mode."
          }
        },
        "title": "audio info",
        "description": "audio info"
      },
      "billing_settings": {
        "type": "object",
        "required": ["purchaseCostCny", "purchasedCredits", "creditsPerGeneration", "outputsPerGeneration", "rateMultiplier", "cnyPerUsd"],
        "properties": {
          "purchaseCostCny": { "type": "number", "example": 120, "description": "Package purchase cost in CNY." },
          "purchasedCredits": { "type": "number", "example": 2500, "description": "Upstream credits included in the package." },
          "creditsPerGeneration": { "type": "number", "example": 10, "description": "Upstream credits consumed by one generation request." },
          "outputsPerGeneration": { "type": "number", "example": 2, "description": "Songs returned by one generation request." },
          "rateMultiplier": { "type": "number", "example": 1, "description": "Billing/group multiplier applied to credits and effective request value." },
          "cnyPerUsd": { "type": "number", "example": 1, "description": "CNY represented by one downstream USD balance unit." },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "billing_settings_update": {
        "type": "object",
        "description": "Every supplied value must be a positive finite number. Omitted fields keep their current values.",
        "properties": {
          "purchaseCostCny": { "type": "number", "example": 120 },
          "purchasedCredits": { "type": "number", "example": 2500 },
          "creditsPerGeneration": { "type": "number", "example": 10 },
          "outputsPerGeneration": { "type": "number", "example": 2 },
          "rateMultiplier": { "type": "number", "example": 1 },
          "cnyPerUsd": { "type": "number", "example": 1 }
        }
      },
      "billing_summary": {
        "type": "object",
        "required": ["costPerCreditCny", "costPerGenerationCny", "costPerOutputCny", "billingPointsPerGeneration", "totalBillablePoints", "generationsPerPackage", "outputsPerPackage", "referencePackageValueCny", "referenceGenerationValueCny", "grossMarginPercent", "sub2apiPerRequestPriceUsd", "sub2apiEffectivePriceUsd"],
        "properties": {
          "costPerCreditCny": { "type": "number", "example": 0.048 },
          "costPerGenerationCny": { "type": "number", "example": 0.48 },
          "costPerOutputCny": { "type": "number", "example": 0.24 },
          "billingPointsPerGeneration": { "type": "number", "example": 10 },
          "totalBillablePoints": { "type": "number", "example": 2500 },
          "generationsPerPackage": { "type": "number", "example": 250 },
          "outputsPerPackage": { "type": "number", "example": 500 },
          "referencePackageValueCny": { "type": "number", "example": 120 },
          "referenceGenerationValueCny": { "type": "number", "example": 0.48 },
          "grossMarginPercent": { "type": "number", "example": 0 },
          "sub2apiPerRequestPriceUsd": { "type": "number", "example": 0.48, "description": "Recommended Sub2API per_request_price before the group multiplier." },
          "sub2apiEffectivePriceUsd": { "type": "number", "example": 0.48, "description": "Effective downstream request value after rateMultiplier." }
        }
      },
      "billing_snapshot": {
        "type": "object",
        "required": ["settings", "summary"],
        "properties": { "settings": { "$ref": "#/components/schemas/billing_settings" }, "summary": { "$ref": "#/components/schemas/billing_summary" } }
      },
      "billing_public_response": {
        "type": "object",
        "required": ["object", "settings", "summary"],
        "properties": { "object": { "type": "string", "enum": ["billing_settings"] }, "settings": { "$ref": "#/components/schemas/billing_settings" }, "summary": { "$ref": "#/components/schemas/billing_summary" } }
      },
      "sub2api_key_billing": {
        "type": "object",
        "required": ["object", "schema_version", "billing_scope", "group_rate_multiplier", "resolved_rate_multiplier", "peak_rate_enabled", "effective_rate_multiplier", "observed_at"],
        "properties": {
          "object": { "type": "string", "enum": ["sub2api.key_billing"] },
          "schema_version": { "type": "integer", "enum": [1] },
          "billing_scope": { "type": "string", "enum": ["token"], "description": "Compatibility value required by the Sub2API probe." },
          "group_rate_multiplier": { "type": "number", "example": 1 },
          "resolved_rate_multiplier": { "type": "number", "example": 1 },
          "peak_rate_enabled": { "type": "boolean", "example": false },
          "effective_rate_multiplier": { "type": "number", "example": 1 },
          "observed_at": { "type": "string", "format": "date-time" }
        }
      },
      "billing_admin_save_response": {
        "type": "object",
        "required": ["ok", "message", "settings", "summary"],
        "properties": { "ok": { "type": "boolean", "example": true }, "message": { "type": "string" }, "settings": { "$ref": "#/components/schemas/billing_settings" }, "summary": { "$ref": "#/components/schemas/billing_summary" } }
      },
      "concurrency_settings": {
        "type": "object",
        "required": ["maxConcurrentRequests"],
        "properties": {
          "maxConcurrentRequests": { "type": "integer", "minimum": 1, "maximum": 100, "default": 4, "example": 4 },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "concurrency_settings_update": {
        "type": "object",
        "required": ["maxConcurrentRequests"],
        "properties": {
          "maxConcurrentRequests": { "type": "integer", "minimum": 1, "maximum": 100, "default": 4, "example": 4 }
        }
      },
      "concurrency_snapshot": {
        "type": "object",
        "required": ["settings", "activeRequests", "availableSlots"],
        "properties": {
          "settings": { "$ref": "#/components/schemas/concurrency_settings" },
          "activeRequests": { "type": "integer", "minimum": 0, "example": 2 },
          "availableSlots": { "type": "integer", "minimum": 0, "example": 2 }
        }
      },
      "concurrency_save_response": {
        "allOf": [
          { "$ref": "#/components/schemas/concurrency_snapshot" },
          {
            "type": "object",
            "required": ["message"],
            "properties": { "message": { "type": "string", "example": "并发限制已保存并立即生效。" } }
          }
        ]
      },
      "concurrency_limit_error": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "object",
            "required": ["message", "type", "code", "limit", "active_requests", "retry_after"],
            "properties": {
              "message": { "type": "string", "example": "Global generation concurrency limit exceeded." },
              "type": { "type": "string", "enum": ["rate_limit_error"] },
              "code": { "type": "string", "enum": ["concurrency_limit_exceeded"] },
              "limit": { "type": "integer", "example": 4 },
              "active_requests": { "type": "integer", "example": 4 },
              "retry_after": { "type": "integer", "example": 5 }
            }
          }
        }
      },
      "model_list": {
        "type": "object",
        "required": ["object", "data"],
        "properties": {
          "object": {
            "type": "string",
            "enum": ["list"]
          },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/suno_model" }
          }
        }
      },
      "suno_model": {
        "type": "object",
        "required": ["id", "object", "created", "owned_by"],
        "properties": {
          "id": {
            "type": "string",
            "enum": ["suno-music", "suno-v5.5", "suno-v5", "suno-v4.5+", "suno-v4.5", "suno-v4", "suno-v3.5", "suno-v3"]
          },
          "object": {
            "type": "string",
            "enum": ["model"]
          },
          "created": {
            "type": "integer",
            "format": "int64",
            "description": "Unix timestamp generated by the catalog endpoint."
          },
          "owned_by": {
            "type": "string",
            "example": "suno-api"
          },
          "capabilities": {
            "type": "array",
            "items": { "type": "string" },
            "example": ["music"]
          },
          "metadata": {
            "type": "object",
            "description": "Suno API extensions describing the provider model, label, status, recommendation, and optional alias target.",
            "required": ["provider", "provider_model", "label", "description", "status", "recommended"],
            "properties": {
              "provider": { "type": "string", "example": "suno" },
              "provider_model": { "type": "string", "example": "chirp-fenix" },
              "label": { "type": "string", "example": "Suno Music (Latest)" },
              "description": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["current", "stable", "legacy"]
              },
              "recommended": { "type": "boolean" },
              "alias_of": { "type": "string" }
            }
          }
        }
      }
    },
    "responses": {
      "ConcurrencyLimitExceeded": {
        "description": "The global generation concurrency limit is full. Retry after a slot is released.",
        "headers": {
          "Retry-After": {
            "description": "Suggested retry delay in seconds.",
            "schema": { "type": "integer", "example": 5 }
          }
        },
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/concurrency_limit_error" }
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "API key" },
      "ApiKeyAuth": { "type": "apiKey", "in": "header", "name": "x-api-key" },
      "AdminSession": { "type": "apiKey", "in": "cookie", "name": "suno_admin_session" }
    }
  }
}
